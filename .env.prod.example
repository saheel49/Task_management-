# Production environment for the Docker Compose stack (config.settings.prod).
#
# Copy this file to `.env.prod`, then replace every "change-me" value with a real
# secret. `.env.prod` is git-ignored — never commit it.
###############################################################################

# --- Django core ------------------------------------------------------------
# REQUIRED in production. Several settings in config/settings/base.py are derived from DEBUG at
# import time (cache backend, Celery eager mode, django-vite dev mode, and dev-only apps such as
# django_browser_reload which are NOT installed in the prod image). Leaving this True will break
# the container, so it must be False here.
DEBUG=False

# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="change-me-to-a-long-random-secret"

# Comma-separated list of the domains this app is served from (no "*").
ALLOWED_HOSTS="example.com,www.example.com"

# Selects config/settings/prod.py (DEBUG=False + security headers + WhiteNoise).
DJANGO_SETTINGS_MODULE=config.settings.prod

# Generate https:// absolute URLs (the app runs behind a TLS-terminating proxy).
USE_HTTPS_IN_ABSOLUTE_URLS=True

# --- Postgres ---------------------------------------------------------------
# Consumed by the `db` service to initialise the database, and must match DATABASE_URL below.
POSTGRES_DB=django_template
POSTGRES_USER=postgres
POSTGRES_PASSWORD="change-me-postgres-password"
# host "db" is the compose service name.
DATABASE_URL="postgresql://postgres:change-me-postgres-password@db:5432/django_template"

# --- Redis (cache + Celery broker) ------------------------------------------
# host "redis" is the compose service name.
REDIS_URL="redis://redis:6379/0"

# --- gunicorn ---------------------------------------------------------------
# Rule of thumb: (2 x CPU cores) + 1.
GUNICORN_WORKERS=3

# --- Email ------------------------------------------------------------------
# The default console backend just logs emails. Configure a real backend for production,
# e.g. Mailgun via Anymail (already installed):
DEFAULT_FROM_EMAIL="noreply@example.com"
SERVER_EMAIL="noreply@example.com"
# EMAIL_BACKEND="anymail.backends.mailgun.EmailBackend"
# MAILGUN_API_KEY="key-***"
# MAILGUN_SENDER_DOMAIN="example.com"

# --- Optional ---------------------------------------------------------------
# PUBLIC-FACING domain used to populate django.contrib.sites on first deploy.
# Set this to your production URL (e.g. https://your-app.onrender.com) so that
# Site.objects.get_current().domain is correct. Falls back to http://localhost:8000.
PROJECT_URL="https://example.com"

GOOGLE_ANALYTICS_ID=""
# TURNSTILE_KEY=""
# TURNSTILE_SECRET=""

# --- Initial Admin Superuser --------------------------------------------------
# These credentials are used only by the `create_admin_superuser` management command
# to seed an initial admin account in production. Set the same values in your Render
# environment if you want matching local + production credentials.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="User"
